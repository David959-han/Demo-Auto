generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── TENANT ──────────────────────────────────────────────────────────────────
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  phone     String?
  email     String?
  address   String?
  city      String?
  country   String   @default("UZ")
  currency  String   @default("USD")
  vatRate   Float    @default(0)
  vatNumber String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  customers  Customer[]
  vehicles   Vehicle[]
  workOrders WorkOrder[]
  mechanics  Mechanic[]
  parts      Part[]
  washBays   WashBay[]
  reminders  Reminder[]
  payments   Payment[]
}

// ─── USER / AUTH ──────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("mechanic") // boss | mechanic | washer
  tenantId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── CUSTOMER ─────────────────────────────────────────────────────────────────
model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  address   String?
  isVip     Boolean  @default(false)
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicles   Vehicle[]
  workOrders WorkOrder[]
  reminders  Reminder[]
}

// ─── VEHICLE ──────────────────────────────────────────────────────────────────
model Vehicle {
  id           String   @id @default(cuid())
  plate        String
  brand        String
  model        String
  year         Int
  color        String?
  vin          String?
  mileage      Int      @default(0)
  insuranceExp DateTime?
  customerId   String
  tenantId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workOrders WorkOrder[]
  reminders  Reminder[]

  @@index([tenantId, plate])
}

// ─── WORK ORDER ───────────────────────────────────────────────────────────────
model WorkOrder {
  id          String    @id @default(cuid())
  orderNumber String
  status      String    @default("pending") // pending | active | done | cancelled
  description String?
  totalCost   Float     @default(0)
  startDate   DateTime  @default(now())
  endDate     DateTime?
  customerId  String
  vehicleId   String
  tenantId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customer   Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicle    Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mechanics  OrderMechanic[]
  payments   Payment[]
  partsUsed  OrderPart[]

  @@index([tenantId, status])
  @@index([tenantId, orderNumber])
}

model OrderMechanic {
  id          String @id @default(cuid())
  workOrderId String
  mechanicId  String

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  mechanic  Mechanic  @relation(fields: [mechanicId], references: [id], onDelete: Cascade)

  @@unique([workOrderId, mechanicId])
}

// ─── MECHANIC ─────────────────────────────────────────────────────────────────
model Mechanic {
  id               String   @id @default(cuid())
  name             String
  specialty        String
  phone            String?
  kpi              Int      @default(80)
  completedOrders  Int      @default(0)
  monthlyRevenue   Float    @default(0)
  tenantId         String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders  OrderMechanic[]

  @@index([tenantId])
}

// ─── PARTS / INVENTORY ────────────────────────────────────────────────────────
model Part {
  id           String   @id @default(cuid())
  name         String
  barcode      String?
  category     String
  price        Float    @default(0)
  quantity     Int      @default(0)
  minThreshold Int      @default(5)
  supplier     String?
  tenantId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usedIn    OrderPart[]

  @@index([tenantId])
}

model OrderPart {
  id          String @id @default(cuid())
  workOrderId String
  partId      String
  quantity    Int    @default(1)
  unitPrice   Float  @default(0)

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  part      Part      @relation(fields: [partId], references: [id], onDelete: Cascade)
}

// ─── WASH BAY ─────────────────────────────────────────────────────────────────
model WashBay {
  id        String   @id @default(cuid())
  bayNumber Int
  status    String   @default("empty") // empty | washing | booked | waiting
  plate     String?
  brand     String?
  startedAt String?
  bookedAt  String?
  tenantId  String
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, bayNumber])
  @@index([tenantId])
}

// ─── REMINDER ─────────────────────────────────────────────────────────────────
model Reminder {
  id         String   @id @default(cuid())
  type       String   // oil | tire | brake | service
  nextKm     Int?
  nextDate   DateTime?
  smsStatus  String   @default("scheduled") // scheduled | sent | failed
  vehicleId  String
  customerId String
  tenantId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ─── PAYMENT ──────────────────────────────────────────────────────────────────
model Payment {
  id          String   @id @default(cuid())
  amount      Float
  method      String   @default("cash") // cash | card | credit
  isPaid      Boolean  @default(false)
  workOrderId String
  tenantId    String
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}
